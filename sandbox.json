{
  "enabled": true,
  "network": {
    "allowNetwork": false,
    "allowLocalBinding": true,
    "allowAllUnixSockets": false,
    "allowUnixSockets": [],
    "allowedDomains": [
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com",
      "objects.githubusercontent.com",
      "codeload.github.com",
      "registry.npmjs.org",
      "npmjs.org",
      "*.npmjs.org",
      "nodejs.org",
      "*.nodejs.org",
      "crates.io",
      "*.crates.io",
      "static.crates.io"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": ["/home"],
    "allowRead": [
      ".",
      "/tmp",
      "/var/tmp",
      "/dev/null",
      "~/.config",
      "~/.gitconfig",
      "~/.local",
      "~/.cargo",
      "~/.rustup",
      "~/.npm",
      "~/.cache",
      "~/.bun",
      "~/.node-gyp"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "/var/tmp",
      "/dev/null",
      "~/.cargo",
      "~/.rustup",
      "~/.npm",
      "~/.cache",
      "~/.bun",
      "~/.node-gyp"
    ],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
